.settings-parent {
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #0008;
	display: flex;
	justify-content: center;
	align-items: center;
	position: absolute;
}

.settings-root {
	box-shadow: #000a 0dp 0dp 8dp 3dp;
	background-color: rgba(50,62,68,180);
	backdrop-filter: blur(12dp);
	border: 1dp rgb(172,176,179);
	border-radius: 0dp;
	width: 70%;
	height: 70%;
	font-size: 28dp;
	padding: 1em;
	display: flex;
	flex-direction: column;
}
